<?xml version="1.0" encoding="utf-8"?>
<!-- Simple globe vector for Whereabouts launcher icon foreground -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Outer circle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,18 a36,36 0 1,0 0.001,0 Z" />
    <!-- Simple crosshair lines to suggest globe -->
    <path
        android:fillColor="#2196F3"
        android:pathData="M54,20 a34,34 0 1,0 0.001,0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,54 L88,54 M54,20 L54,88"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3" />
    <!-- Latitude arc -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:pathData="M23,42 Q54,50 85,42 M23,66 Q54,58 85,66" />
    <!-- Longitude arc -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:pathData="M54,20 Q42,54 54,88 M54,20 Q66,54 54,88" />
</vector>
